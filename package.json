{
  "name": "playwright-automation",
  "version": "1.0.0",
  "description": "Playwright + Cucumber + Allure Framework",
  "main": "index.js",
  "scripts": {
    "clean:allure": "rimraf allure-results allure-report",
    "test": "npm run clean:allure && cucumber-js",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "test:report": "npm run test && npm run allure:generate && npm run allure:open"
  },
  "type": "commonjs",
  "devDependencies": {
    "@cucumber/cucumber": "^12.8.1",
    "@cucumber/messages": "^32.3.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "allure-commandline": "^2.38.1",
    "allure-cucumberjs": "^3.7.1",
    "allure-js-commons": "^3.7.1",
    "rimraf": "^5.0.5",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
